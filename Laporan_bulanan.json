      "parameters": {
        "jsCode": "let totalUnit = 0;\nlet totalPendapatan = 0;\nlet data = items;\n\nfor (const item of data) {\n  // Ambil data sesuai nama kolom di Master Sheet\n  totalUnit += Number(item.json[\"Penjualan (Unit)\"] || 0);\n  totalPendapatan += Number(item.json[\"Pendapatan\"] || 0);\n}\n\nreturn [{\n  json: {\n    Bulan: \"Mei\",\n    Total_Penjualan: totalUnit,\n    Total_Pendapatan: totalPendapatan,\n    Jumlah_Laporan: data.length,\n    Rata_Rata: (totalPendapatan / data.length).toFixed(2)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        352
      ],
      "id": "3e764039-bfa1-44f9-ab9d-240b3077950c",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// Memastikan data siap untuk digabung (Merge1)\nreturn items.map(item => {\n  const data = item.json;\n\n  return {\n    json: {\n      // Pastikan nama kolom di kiri (misal: \"Pendapatan\") \n      // sama persis dengan kolom di jalur atas (Sheet 1 & 2)\n      \"ID Laporan\": data[\"ID Laporan\"] || data.id || \"-\",\n      \"Bulan\": data.Bulan || \"Mei\",\n      \"Penjualan (Unit)\": Number(data[\"Penjualan (Unit)\"] || data.qty || 0),\n      \"Pendapatan\": Number(data.Pendapatan || data.total || 0),\n      \"Produk\": data.Produk || \"General\",\n      \"Sumber\": \"Sheet_Data_External\" // Penanda sumber data\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
