    {
      "parameters": {
        "jsCode": "\nconst allData = items;\n\n// 2. Siapkan variabel penampung hitungan\nlet totalUnit = 0;\nlet totalPendapatan = 0;\nlet jumlahTransaksi = allData.length;\n\n// 3. Mulai perhitungan (Looping)\nfor (const item of allData) {\n  // Pastikan nama kolom di dalam [\"\"] sesuai dengan nama kolom di Master Sheet kamu\n  totalUnit += Number(item.json[\"Penjualan (Unit)\"] || 0);\n  totalPendapatan += Number(item.json[\"Pendapatan\"] || 0);\n}\n\n// 4. Hitung rata-rata performa\nlet rataRata = jumlahTransaksi > 0 ? (totalPendapatan / jumlahTransaksi) : 0;\n\n// 5. Kembalikan hasil sebagai satu objek ringkasan\nreturn [{\n  json: {\n    Bulan: \"Mei\", \n    Tahun: 2026,\n    Total_Unit_Terjual: totalUnit,\n    Total_Revenue: totalPendapatan,\n    Jumlah_Laporan_Masuk: jumlahTransaksi,\n    Rata_Rata_Performa: rataRata.toFixed(2), // Membatasi 2 angka di belakang koma\n    Waktu_Update: new Date().toLocaleString('id-ID')\n  }\n}];"
      },
